# =============================================================================
# Qimmiit SDK Dev Package Configuration File
# =============================================================================
#
# This file is used by CMake's find_package() command to find the Qimmiit SDK
#
# Usage in your CMakeLists.txt:
#   find_package(QimmiitSDKDev REQUIRED)
#   target_link_libraries(your-target PRIVATE Qimmiit::SDK)
#

@PACKAGE_INIT@

# Include the targets file
include("${CMAKE_CURRENT_LIST_DIR}/QimmiitSDKDevTargets.cmake")

# Set found flag
set(QimmiitSDKDev_FOUND TRUE)

# Version information
set(QimmiitSDKDev_VERSION "@PROJECT_VERSION@")

# Check required components
check_required_components(QimmiitSDKDev)

# Provide information about available modules
set(QimmiitSDKDev_MODULES)

if(TARGET Qimmiit::SDK)
    list(APPEND QimmiitSDKDev_MODULES SDK)
endif()

# Print configuration info
if(NOT QimmiitSDKDev_FIND_QUIETLY)
    message(STATUS "Found QimmiitSDKDev: ${QimmiitSDKDev_VERSION}")
    message(STATUS "  Available modules: ${QimmiitSDKDev_MODULES}")
endif()
