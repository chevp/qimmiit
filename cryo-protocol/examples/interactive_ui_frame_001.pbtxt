# Interactive UI Frame 001
# Delta frame: +100ms - Client-side hover prediction
# Client predicts button hover, no server confirmation needed yet

frame_number: 1
timestamp_ms: 100
type: DELTA
reference_frames: 0

# ============================================================================
# MESSAGE GROUP: Client Interaction Prediction
# ============================================================================
groups {
  group_id: "client_interaction_001"
  purpose: "ui_hover_prediction"
  priority: HIGH
  atomic: false

  # Client predicted hover event
  data {
    [type.googleapis.com/cryo.client.LocalPrediction] {
      prediction_id: "pred_hover_btn_primary_001"
      client_timestamp_ms: 100

      ui_interaction {
        element_id: "btn_primary"
        predicted_state: HOVER
        interaction_type: "hover"
      }

      status: PENDING
      ttl_seconds: 5.0
    }
  }

  # Hover state update (client-side)
  data {
    [type.googleapis.com/cryo.ui.UIElementState] {
      element_id: "btn_primary"
      is_visible: true
      is_enabled: true
      opacity: 1.0
      interaction_state: HOVER  # Changed from NORMAL to HOVER
      is_focused: false
    }
  }

  # Interaction event
  data {
    [type.googleapis.com/cryo.ui.UIInteractionEvent] {
      event_id: "event_hover_enter_001"
      timestamp_ms: 100
      element_id: "btn_primary"

      hover_enter {
        position { x: 150.0 y: 125.0 }
        previous_position { x: 50.0 y: 50.0 }
        from_element_id: ""
      }

      bubbles: true
      cancelable: false
      is_predicted: true  # Client predicted
      needs_server_confirmation: false  # Hover doesn't need confirmation
    }
  }

  # Client interaction state
  data {
    [type.googleapis.com/cryo.client.ClientInteractionState] {
      pointer_position { x: 150.0 y: 125.0 }
      pointer_down: false

      hovered_element_ids: "btn_primary"

      hover_states {
        key: "btn_primary"
        value {
          element_id: "btn_primary"
          hover_start_time: 0.1
          hover_duration: 0.0
          hover_position { x: 150.0 y: 125.0 }
          hover_animation_progress: 0.0  # Animation just starting
        }
      }

      last_interaction_ms: 100
    }
  }
}

metadata {
  frame_size_bytes: 512
  uncompressed_size_bytes: 768
  message_count: 4
  group_count: 1
  quality_factor: 1.0
  is_keyframe: false
}

compression {
  method: NONE  # Small delta, no compression needed
}