# Interactive UI Frame 005
# Delta frame: +6200ms - Client surviving without server (5+ seconds!)
# Shows how client maintains interactivity during network delay

frame_number: 5
timestamp_ms: 6200
type: DELTA
reference_frames: 4

# ============================================================================
# MESSAGE GROUP: Client Extrapolation (Surviving without server)
# ============================================================================
groups {
  group_id: "client_survival_005"
  purpose: "client_state_extrapolation"
  priority: NORMAL
  atomic: false

  # Client is hovering slider (all client-side, no server needed)
  data {
    [type.googleapis.com/cryo.ui.UIElementState] {
      element_id: "slider_volume"
      is_visible: true
      is_enabled: true
      opacity: 1.0
      interaction_state: HOVER
      is_focused: false
    }
  }

  # Hover prediction
  data {
    [type.googleapis.com/cryo.client.LocalPrediction] {
      prediction_id: "pred_hover_slider_005"
      client_timestamp_ms: 6200

      ui_interaction {
        element_id: "slider_volume"
        predicted_state: HOVER
        interaction_type: "hover"
      }

      status: PENDING
      ttl_seconds: 5.0
    }
  }

  # Client interaction state
  data {
    [type.googleapis.com/cryo.client.ClientInteractionState] {
      pointer_position { x: 180.0 y: 275.0 }
      pointer_down: false

      hovered_element_ids: "slider_volume"

      hover_states {
        key: "slider_volume"
        value {
          element_id: "slider_volume"
          hover_start_time: 6.1
          hover_duration: 0.1
          hover_position { x: 180.0 y: 275.0 }
          hover_animation_progress: 0.5
        }
      }

      last_interaction_ms: 6200
    }
  }

  # Status indicator changes to yellow (warning: server delayed)
  data {
    [type.googleapis.com/cryo.ui.UIElementState] {
      element_id: "status_indicator"
      is_visible: true
      is_enabled: true
      opacity: 1.0
      # Background color changes to yellow (client-side)
      state_flags {
        key: "server_delayed"
        value: true
      }
    }
  }
}

# ============================================================================
# MESSAGE GROUP: Buffer Statistics (showing survival mode)
# ============================================================================
groups {
  group_id: "survival_stats_005"
  purpose: "client_survival_statistics"
  priority: LOW
  atomic: false

  data {
    [type.googleapis.com/cryo.client.BufferStatistics] {
      total_updates_received: 2
      updates_in_last_second: 0
      average_update_interval_ms: 1100.0

      ms_since_last_update: 5100  # 5.1 seconds without server!

      predictions_made: 3
      predictions_confirmed: 2
      predictions_rejected: 0
      prediction_accuracy: 1.0

      interpolation_buffer_size: 2
      is_extrapolating: true  # Client is extrapolating!
      extrapolation_time_ms: 5100

      average_latency_ms: 50.0
      latency_jitter_ms: 10.0
    }
  }
}

metadata {
  frame_size_bytes: 512
  uncompressed_size_bytes: 768
  message_count: 5
  group_count: 2
  quality_factor: 0.9
  is_keyframe: false
  custom_metadata {
    key: "survival_mode"
    value: "true"
  }
  custom_metadata {
    key: "ms_without_server"
    value: "5100"
  }
}