# Interactive UI Frame 003
# Delta frame: +600ms - Button click (needs server confirmation)
# Client predicts click, but waits for server to confirm action

frame_number: 3
timestamp_ms: 600
type: DELTA
reference_frames: 2

# ============================================================================
# MESSAGE GROUP: Button Click Prediction
# ============================================================================
groups {
  group_id: "click_prediction_003"
  purpose: "ui_click_prediction"
  priority: CRITICAL
  atomic: true

  # Click prediction
  data {
    [type.googleapis.com/cryo.client.LocalPrediction] {
      prediction_id: "pred_click_btn_primary_003"
      client_timestamp_ms: 600

      ui_interaction {
        element_id: "btn_primary"
        predicted_state: PRESSED
        interaction_type: "click"
      }

      status: PENDING
      ttl_seconds: 5.0
    }
  }

  # Element state change to PRESSED
  data {
    [type.googleapis.com/cryo.ui.UIElementState] {
      element_id: "btn_primary"
      is_visible: true
      is_enabled: true
      opacity: 1.0
      interaction_state: PRESSED  # Changed from HOVER to PRESSED
      is_focused: true  # Gained focus from click
    }
  }

  # Pointer down event
  data {
    [type.googleapis.com/cryo.ui.UIInteractionEvent] {
      event_id: "event_pointer_down_003"
      timestamp_ms: 600
      element_id: "btn_primary"

      pointer_down {
        position { x: 158.0 y: 128.0 }
        button: 0  # Left mouse button
        modifier_keys: 0
      }

      bubbles: true
      cancelable: true
      is_predicted: true
      needs_server_confirmation: true  # Click needs confirmation!
    }
  }

  # Client update request (sent to server)
  data {
    [type.googleapis.com/cryo.client.ClientUpdateRequest] {
      client_id: "client_001"
      client_timestamp_ms: 600
      last_received_frame: 0
      last_received_timestamp_ms: 0

      actions {
        action_id: "action_click_001"
        timestamp_ms: 600
        ui_click {
          element_id: "btn_primary"
          click_position { x: 158.0 y: 128.0 }
          button: 0
        }
      }

      requested_entity_ids: []
      requested_ui_element_ids: "btn_primary"
    }
  }

  # Client interaction state
  data {
    [type.googleapis.com/cryo.client.ClientInteractionState] {
      pointer_position { x: 158.0 y: 128.0 }
      pointer_down: true  # Pointer is now down

      hovered_element_ids: "btn_primary"
      pressed_element_ids: "btn_primary"
      focused_element_id: "btn_primary"

      hover_states {
        key: "btn_primary"
        value {
          element_id: "btn_primary"
          hover_start_time: 0.1
          hover_duration: 0.5
          hover_position { x: 158.0 y: 128.0 }
          hover_animation_progress: 1.0  # Hover animation complete
        }
      }

      last_interaction_ms: 600
    }
  }
}

metadata {
  frame_size_bytes: 768
  uncompressed_size_bytes: 1152
  message_count: 5
  group_count: 1
  quality_factor: 1.0
  is_keyframe: false
}