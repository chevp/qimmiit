# Interactive UI Frame 002
# Delta frame: +250ms - Hover animation progressing
# Still no server update needed, client handles animation

frame_number: 2
timestamp_ms: 250
type: DELTA
reference_frames: 1

# ============================================================================
# MESSAGE GROUP: Hover Animation Progress
# ============================================================================
groups {
  group_id: "hover_animation_002"
  purpose: "ui_hover_animation"
  priority: NORMAL
  atomic: false

  # Updated hover state with animation progress
  data {
    [type.googleapis.com/cryo.client.ClientInteractionState] {
      pointer_position { x: 155.0 y: 127.0 }
      pointer_down: false

      hovered_element_ids: "btn_primary"

      hover_states {
        key: "btn_primary"
        value {
          element_id: "btn_primary"
          hover_start_time: 0.1
          hover_duration: 0.15  # 150ms elapsed
          hover_position { x: 155.0 y: 127.0 }
          hover_animation_progress: 0.75  # 75% through hover transition
        }
      }

      last_interaction_ms: 250
    }
  }

  # Hover move event
  data {
    [type.googleapis.com/cryo.ui.UIInteractionEvent] {
      event_id: "event_hover_move_002"
      timestamp_ms: 250
      element_id: "btn_primary"

      hover_move {
        position { x: 155.0 y: 127.0 }
        delta { x: 5.0 y: 2.0 }
        hover_duration: 0.15
      }

      bubbles: false
      cancelable: false
      is_predicted: true
      needs_server_confirmation: false
    }
  }
}

metadata {
  frame_size_bytes: 256
  uncompressed_size_bytes: 384
  message_count: 2
  group_count: 1
  quality_factor: 1.0
  is_keyframe: false
}