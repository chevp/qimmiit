# Teleporter Template - Portal/teleporter pad
# URL: https://cdn.example.com/templates/teleporter.v1.pb

template_id: "teleporter"
template_name: "Teleporter Pad"
template_version: "1.0.0"

metadata {
  author: "Game Studio"
  description: "Teleporter pad that transports player to destination"
  category: "triggers"
  required_assets: "teleport_pad_mesh"
  required_assets: "teleport_sound"
  required_assets: "portal_effect"
  estimated_size_bytes: 2432
}

entity_definition {
  mesh_id: "teleport_pad_mesh"
  material_id: "teleport_material"
  default_scale { x: 2.0 y: 0.2 z: 2.0 }
  collision {
    cylinder {
      radius: 1.0
      height: 0.2
      center { x: 0.0 y: 0.1 z: 0.0 }
    }
  }
}

animations {
  animation_name: "activate"
  animation_asset_id: "teleport_activate_anim"
  default_speed: 1.0
  default_loop: false
}

sounds {
  sound_id: "teleport_activate"
  sound_asset_id: "audio/effects/teleport_activate.ogg"
  default_volume: 0.8
  is_3d: true
}

sounds {
  sound_id: "teleport_whoosh"
  sound_asset_id: "audio/effects/teleport_whoosh.ogg"
  default_volume: 0.9
  is_3d: false  # Global sound
}

# TRIGGER: Idle portal effect
triggers {
  trigger_id: "trigger_teleport_idle"
  condition {
    has_property { property_name: "is_active" operator: EQUAL bool_value: true }
  }
  while_active {
    play_effect {
      effect_id: "portal_effect"
      position { x: 0.0 y: 0.1 z: 0.0 }
      scale: 2.0
      duration: -1.0  # Infinite
    }
    client_side: true
  }
  while_active {
    set_color {
      color { r: 0.2 g: 0.6 b: 1.0 a: 0.8 }
      transition_time: 0.5
      property: "emissive"
    }
    client_side: true
  }
  options { enabled: true }
}

# TRIGGER: Pulsing animation
triggers {
  trigger_id: "trigger_teleport_pulse"
  condition {
    every_interval { interval_seconds: 2.0 }
  }
  on_enter {
    scale_to {
      target_scale { x: 2.1 y: 0.2 z: 2.1 }
      relative: false
    }
    duration: 1.0
    easing: "ease_in_out_sine"
    client_side: true
  }
  on_enter {
    delay: 1.0
    scale_to {
      target_scale { x: 2.0 y: 0.2 z: 2.0 }
      relative: false
    }
    duration: 1.0
    easing: "ease_in_out_sine"
    client_side: true
  }
  options { enabled: true }
}

# TRIGGER: Player enters teleporter
triggers {
  trigger_id: "trigger_teleport_enter"
  condition {
    and_condition {
      conditions {
        on_stand {
          surface_tolerance: 0.5
          require_grounded: true
        }
      }
      conditions {
        has_property { property_name: "is_active" operator: EQUAL bool_value: true }
      }
      conditions {
        has_property { property_name: "destination" operator: NOT_EQUAL string_value: "" }
      }
    }
  }
  on_enter {
    play_animation { animation_name: "activate" speed: 1.5 loop: false }
    client_side: true
  }
  on_enter {
    play_sound { sound_id: "teleport_activate" volume: 0.8 spatial_mode: POSITIONAL_3D }
    client_side: true
  }
  on_enter {
    delay: 0.5
    play_effect {
      effect_id: "teleport_burst"
      position { x: 0.0 y: 0.5 z: 0.0 }
      scale: 3.0
      duration: 1.5
    }
    client_side: true
  }
  on_enter {
    delay: 0.5
    play_sound { sound_id: "teleport_whoosh" volume: 0.9 spatial_mode: AMBIENT }
    client_side: true
  }
  on_enter {
    delay: 0.8
    run_script {
      function_name: "teleport_player"
      # Reads "destination" property for target location
    }
    client_side: false  # Server-side teleport logic
  }
  on_enter {
    delay: 0.8
    shake_camera { intensity: 0.4 frequency: 30.0 }
    duration: 0.3
    client_side: true
  }
  options { enabled: true cooldown: 2.0 }
}

# TRIGGER: Proximity warning (close but not on pad)
triggers {
  trigger_id: "trigger_teleport_proximity"
  condition {
    and_condition {
      conditions { if_near { target_entity_id: "player" distance: 3.0 } }
      conditions { has_property { property_name: "is_active" operator: EQUAL bool_value: true } }
    }
  }
  on_enter {
    show_ui {
      ui_element_id: "ui_teleport_prompt"
      fade_in_time: 0.3
    }
    client_side: true
  }
  on_exit {
    hide_ui {
      ui_element_id: "ui_teleport_prompt"
      fade_out_time: 0.3
    }
    client_side: true
  }
  options { enabled: true retrigger_on_exit: true }
}

default_properties {
  key: "is_active"
  value: "true"
}

default_properties {
  key: "destination"
  value: ""  # Set by instance
}

default_properties {
  key: "destination_name"
  value: "Unknown"
}

default_properties {
  key: "is_one_way"
  value: "false"
}

tags: "trigger"
tags: "teleporter"
tags: "portal"
tags: "transport"
tags: "interactive"