{
  "output_directory": ".cache/render/",
  "max_concurrent_jobs": 8,
  "fail_fast": false,
  "create_output_dirs": true,
  "jobs": [
    {
      "job_id": "player_idle",
      "output_path": ".cache/render/player_idle.png",
      "width": 512,
      "height": 512,
      "scene_template": "scenes/character_template.arctic",
      "scene_parameters": {
        "character_model": "models/knight.glb",
        "animation": "idle"
      },
      "camera": {"position": [0, 1, -3], "target": [0, 0.5, 0]},
      "enable_transparency": true
    },
    {
      "job_id": "player_walk_01",
      "output_path": ".cache/render/player_walk_01.png",
      "width": 512,
      "height": 512,
      "scene_template": "scenes/character_template.arctic",
      "scene_parameters": {
        "character_model": "models/knight.glb",
        "animation": "walk",
        "animation_time": 0.0
      },
      "camera": {"position": [0, 1, -3], "target": [0, 0.5, 0]},
      "enable_transparency": true
    },
    {
      "job_id": "player_walk_02",
      "output_path": ".cache/render/player_walk_02.png",
      "width": 512,
      "height": 512,
      "scene_template": "scenes/character_template.arctic",
      "scene_parameters": {
        "character_model": "models/knight.glb",
        "animation": "walk",
        "animation_time": 0.25
      },
      "camera": {"position": [0, 1, -3], "target": [0, 0.5, 0]},
      "enable_transparency": true
    },
    {
      "job_id": "player_attack",
      "output_path": ".cache/render/player_attack.png",
      "width": 512,
      "height": 512,
      "scene_template": "scenes/character_template.arctic",
      "scene_parameters": {
        "character_model": "models/knight.glb",
        "animation": "attack",
        "animation_time": 0.5
      },
      "camera": {"position": [0, 1, -3], "target": [0, 0.5, 0]},
      "enable_transparency": true
    },
    {
      "job_id": "enemy_goblin",
      "output_path": ".cache/render/enemy_goblin.png",
      "width": 512,
      "height": 512,
      "scene_template": "scenes/character_template.arctic",
      "scene_parameters": {
        "character_model": "models/goblin.glb",
        "animation": "idle"
      },
      "camera": {"position": [0, 0.8, -2.5], "target": [0, 0.4, 0]},
      "enable_transparency": true
    }
  ]
}