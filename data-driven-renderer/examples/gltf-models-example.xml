<?xml version="1.0" encoding="UTF-8"?>
<!--
  Data-Driven Renderer Example: GLTF Models Approach

  This example demonstrates a traditional 3D game scene with multiple
  GLTF models, PBR materials, and dynamic lighting - all driven by
  server-side shader instance updates.

  Use case: 3D game world with characters, props, and environment
-->
<data-driven-scene xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:noNamespaceSchemaLocation="../schemas/data_driven_scene.v1.xsd"
  id="gltf-game-scene" version="1.0.0">

  <name>GLTF Game Scene</name>
  <description>Server-driven 3D scene with PBR GLTF models and real-time lighting</description>

  <!-- gRPC backend connection (Central Java Runtime Server) -->
  <backend>
    <grpc>
      <address>127.0.0.1:9081</address>
      <service>rendering.RendererService</service>
      <stream>StreamRenderingUpdates</stream>
      <tls>false</tls>
    </grpc>
  </backend>

  <!-- Shader templates: PBR variants for different material types -->
  <shader-templates>
    <template id="pbr_standard" src="apps/desktop/penguin-on-screen/pbr-shader-template-example.json" />
    <template id="pbr_glass" src="shaders/templates/pbr_glass.json" />
    <template id="pbr_emissive" src="shaders/templates/pbr_emissive.json" />
    <template id="pbr_clearcoat" src="shaders/templates/pbr_clearcoat.json" />
    <template id="skybox" src="shaders/templates/skybox.json" />
  </shader-templates>

  <!-- Shader instances: Each GLTF model becomes a shader instance -->
  <shader-instances>

    <!-- Main character (Suzanne in Box model) -->
    <instance id="character_suzanne" template="pbr_standard">
      <uniforms>
        <uniform name="base_color_factor" type="vec4" value="1.0, 1.0, 1.0, 1.0" />
        <uniform name="metallic_factor" type="float" value="0.0" />
        <uniform name="roughness_factor" type="float" value="0.7" />
        <uniform name="normal_scale" type="float" value="1.0" />
        <uniform name="occlusion_strength" type="float" value="1.0" />
      </uniforms>
      <textures>
        <texture binding="base_color_texture" src="models/suzanne-in-box/textures/Suzanne_BaseColor.png">
          <sampler mag_filter="LINEAR" min_filter="LINEAR" address_mode="REPEAT" />
        </texture>
        <texture binding="normal_texture" src="models/suzanne-in-box/textures/Suzanne_Normal.png">
          <sampler mag_filter="LINEAR" min_filter="LINEAR" />
        </texture>
        <texture binding="metallic_roughness_texture" src="models/suzanne-in-box/textures/Suzanne_Metallic_Roughness.png">
          <sampler mag_filter="LINEAR" min_filter="LINEAR" />
        </texture>
      </textures>
      <geometry>
        <mesh src="asset://models/suzanne-in-box/SuzanneInBox.gltf" />
      </geometry>
      <transform>
        <position x="0.0" y="1.0" z="0.0" />
        <rotation x="0.0" y="0.0" z="0.0" />
        <scale x="1.0" y="1.0" z="1.0" />
      </transform>
    </instance>

    <!-- Metal crate prop (metallic PBR material) -->
    <instance id="prop_metal_crate" template="pbr_standard">
      <uniforms>
        <uniform name="base_color_factor" type="vec4" value="1.0, 1.0, 1.0, 1.0" />
        <uniform name="metallic_factor" type="float" value="1.0" />
        <uniform name="roughness_factor" type="float" value="0.3" />
        <uniform name="normal_scale" type="float" value="1.5" />
        <uniform name="occlusion_strength" type="float" value="0.8" />
      </uniforms>
      <textures>
        <texture binding="base_color_texture" src="textures/metal_plate_albedo.png">
          <sampler mag_filter="LINEAR" min_filter="LINEAR" address_mode="REPEAT" />
        </texture>
        <texture binding="normal_texture" src="textures/metal_plate_normal.png">
          <sampler mag_filter="LINEAR" min_filter="LINEAR" />
        </texture>
        <texture binding="metallic_roughness_texture" src="textures/metal_plate_metallic_roughness.png">
          <sampler mag_filter="LINEAR" min_filter="LINEAR" />
        </texture>
        <texture binding="occlusion_texture" src="textures/metal_plate_ao.png">
          <sampler mag_filter="LINEAR" min_filter="LINEAR" />
        </texture>
      </textures>
      <geometry>
        <mesh src="models/crate.gltf" />
      </geometry>
      <transform>
        <position x="-3.0" y="0.5" z="0.0" />
        <rotation x="0.0" y="45.0" z="0.0" />
        <scale x="1.0" y="1.0" z="1.0" />
      </transform>
    </instance>

    <!-- Glass window (transmission material) -->
    <instance id="env_glass_window" template="pbr_glass">
      <specialization-constants>
        <constant name="USE_TRANSMISSION" type="bool" value="true" />
        <constant name="USE_ALPHA_MASK" type="bool" value="false" />
      </specialization-constants>
      <uniforms>
        <uniform name="base_color_factor" type="vec4" value="0.95, 0.98, 1.0, 0.15" />
        <uniform name="metallic_factor" type="float" value="0.0" />
        <uniform name="roughness_factor" type="float" value="0.05" />
        <uniform name="transmission_factor" type="float" value="0.95" />
        <uniform name="ior" type="float" value="1.52" />
      </uniforms>
      <geometry>
        <mesh src="models/window_panel.gltf" />
      </geometry>
      <transform>
        <position x="5.0" y="2.5" z="-2.0" />
        <rotation x="0.0" y="0.0" z="0.0" />
        <scale x="2.0" y="3.0" z="0.1" />
      </transform>
    </instance>

    <!-- Glowing portal (emissive material) -->
    <instance id="env_portal" template="pbr_emissive">
      <specialization-constants>
        <constant name="USE_EMISSIVE_MAP" type="bool" value="true" />
      </specialization-constants>
      <uniforms>
        <uniform name="base_color_factor" type="vec4" value="0.1, 0.1, 0.2, 1.0" />
        <uniform name="metallic_factor" type="float" value="0.0" />
        <uniform name="roughness_factor" type="float" value="0.9" />
        <uniform name="emissive_factor" type="vec3" value="0.2, 0.8, 1.5" />
        <uniform name="emissive_strength" type="float" value="5.0" />
      </uniforms>
      <textures>
        <texture binding="emissive_texture" src="textures/portal_emissive.png">
          <sampler mag_filter="LINEAR" min_filter="LINEAR" address_mode="REPEAT" />
        </texture>
      </textures>
      <geometry>
        <mesh src="models/portal_ring.gltf" />
      </geometry>
      <transform>
        <position x="8.0" y="2.0" z="0.0" />
        <rotation x="0.0" y="90.0" z="0.0" />
        <scale x="1.5" y="1.5" z="0.1" />
      </transform>
    </instance>

    <!-- Car prop (clearcoat material - car paint) -->
    <instance id="prop_race_car" template="pbr_clearcoat">
      <specialization-constants>
        <constant name="USE_CLEARCOAT" type="bool" value="true" />
      </specialization-constants>
      <uniforms>
        <uniform name="base_color_factor" type="vec4" value="0.9, 0.1, 0.1, 1.0" />
        <uniform name="metallic_factor" type="float" value="0.8" />
        <uniform name="roughness_factor" type="float" value="0.4" />
        <uniform name="clearcoat_factor" type="float" value="1.0" />
        <uniform name="clearcoat_roughness" type="float" value="0.05" />
      </uniforms>
      <textures>
        <texture binding="base_color_texture" src="models/car/car_paint_red.png">
          <sampler mag_filter="LINEAR" min_filter="LINEAR" />
        </texture>
        <texture binding="clearcoat_texture" src="textures/clearcoat.png">
          <sampler mag_filter="LINEAR" min_filter="LINEAR" />
        </texture>
        <texture binding="clearcoat_roughness_texture" src="textures/clearcoat_roughness.png">
          <sampler mag_filter="LINEAR" min_filter="LINEAR" />
        </texture>
      </textures>
      <geometry>
        <mesh src="models/race_car.gltf" />
      </geometry>
      <transform>
        <position x="3.0" y="0.0" z="5.0" />
        <rotation x="0.0" y="180.0" z="0.0" />
        <scale x="1.0" y="1.0" z="1.0" />
      </transform>
    </instance>

    <!-- Skybox environment (cubemap) -->
    <instance id="env_skybox" template="skybox">
      <textures>
        <texture binding="skybox_cubemap" src="textures/environment/papermill_cube.ktx">
          <sampler mag_filter="LINEAR" min_filter="LINEAR" address_mode="CLAMP_TO_EDGE" />
        </texture>
      </textures>
      <geometry>
        <cube />
      </geometry>
      <transform>
        <position x="0.0" y="0.0" z="0.0" />
        <scale x="1000.0" y="1000.0" z="1000.0" />
      </transform>
    </instance>

  </shader-instances>

  <!-- Server-driven update rules: Real-time shader instance updates -->
  <update-rules>

    <!-- Character movement: Server sends position/rotation updates at 30Hz -->
    <rule instance="character_suzanne" stream="grpc" rate="30hz">
      <update-transform />
    </rule>

    <!-- Portal animation: Emissive strength pulsing effect -->
    <rule instance="env_portal" stream="grpc" rate="10hz">
      <update-uniform name="emissive_strength" />
    </rule>

    <!-- Car position updates (player-controlled or AI) -->
    <rule instance="prop_race_car" stream="grpc" rate="60hz">
      <update-transform />
    </rule>

    <!-- Dynamic crate weathering: Roughness changes over time -->
    <rule instance="prop_metal_crate" stream="grpc" rate="0.1hz">
      <update-uniform name="roughness_factor" />
    </rule>

  </update-rules>

  <!-- Camera: Third-person perspective -->
  <camera>
    <type>PERSPECTIVE</type>
    <fov>60.0</fov>
    <near>0.1</near>
    <far>1000.0</far>
    <position x="0.0" y="5.0" z="15.0" />
    <rotation x="-15.0" y="0.0" z="0.0" />
  </camera>

  <!-- Environment: Image-based lighting for realistic PBR -->
  <environment>
    <ambient-light color="0.2, 0.2, 0.25" intensity="0.5" />
    <ibl>
      <irradiance-map src="textures/environment/papermill_irradiance_cube.ktx" />
      <prefiltered-map src="textures/environment/papermill_prefiltered_cube.ktx" />
      <brdf-lut src="textures/brdf_lut.png" />
    </ibl>
  </environment>

  <!-- Lights: Dynamic lighting setup -->
  <lights>

    <!-- Main sunlight -->
    <directional-light id="sun">
      <direction x="-0.4" y="-1.0" z="-0.6" />
      <color r="1.0" g="0.95" b="0.85" />
      <intensity>4.0</intensity>
    </directional-light>

    <!-- Portal light (point light matching emissive color) -->
    <point-light id="portal_light">
      <position x="8.0" y="2.0" z="0.0" />
      <color r="0.2" g="0.8" b="1.5" />
      <intensity>15.0</intensity>
      <range>10.0</range>
    </point-light>

    <!-- Street lamp -->
    <point-light id="street_lamp">
      <position x="-5.0" y="4.0" z="3.0" />
      <color r="1.0" g="0.85" b="0.6" />
      <intensity>12.0</intensity>
      <range>12.0</range>
    </point-light>

  </lights>

  <!-- Assets: GLTF models and textures to preload -->
  <assets>

    <!-- GLTF Models -->
    <mesh id="suzanne_in_box" src="asset://models/suzanne-in-box/SuzanneInBox.gltf" />
    <mesh id="metal_crate" src="models/crate.gltf" />
    <mesh id="glass_window" src="models/window_panel.gltf" />
    <mesh id="portal_ring" src="models/portal_ring.gltf" />
    <mesh id="race_car" src="models/race_car.gltf" />

    <!-- PBR Textures -->
    <texture id="metal_plate_albedo" src="textures/metal_plate_albedo.png" />
    <texture id="metal_plate_normal" src="textures/metal_plate_normal.png" />
    <texture id="metal_plate_metallic_roughness" src="textures/metal_plate_metallic_roughness.png" />
    <texture id="metal_plate_ao" src="textures/metal_plate_ao.png" />
    <texture id="portal_emissive" src="textures/portal_emissive.png" />
    <texture id="clearcoat" src="textures/clearcoat.png" />
    <texture id="brdf_lut" src="textures/brdf_lut.png" />

    <!-- Environment maps -->
    <texture id="papermill_irradiance" src="textures/environment/papermill_irradiance_cube.ktx" />
    <texture id="papermill_prefiltered" src="textures/environment/papermill_prefiltered_cube.ktx" />
    <texture id="papermill_skybox" src="textures/environment/papermill_cube.ktx" />

  </assets>

  <!-- Events: Server interactions and telemetry -->
  <events>

    <!-- Server shader update via gRPC -->
    <event name="grpc_shader_update">
      <action type="update_shader_instance" />
    </event>

    <!-- User input events forwarded to server -->
    <event name="user_input">
      <action type="notify_server" />
    </event>

    <!-- Periodic telemetry to server (every second) -->
    <event name="frame_rendered" rate="1hz">
      <action type="send_telemetry">
        <param name="frame_time_ms" source="renderer" />
        <param name="draw_calls" source="renderer" />
        <param name="triangles_rendered" source="renderer" />
        <param name="shader_instance_count" source="renderer" />
      </action>
    </event>

    <!-- Asset loaded notification -->
    <event name="asset_loaded">
      <action type="notify_server">
        <param name="asset_id" source="event" />
        <param name="load_time_ms" source="event" />
      </action>
    </event>

  </events>

  <!-- Studio mode: ImGui debug UI (disabled in production) -->
  <studio-mode enabled="false">
    <imgui-theme>
      <widget type="button" shader-template="ui_gradient_button" />
      <widget type="panel" shader-template="ui_panel" />
    </imgui-theme>
  </studio-mode>

</data-driven-scene>
