/**
 * Tool Launcher Implementation
 */

#include <coregfx/overlay/tool_launcher.hpp>
#include <coregfx/core/ocean_log.hpp>

#include <shellapi.h>
#include <tlhelp32.h>
#include <sstream>
#include <thread>
#include <chrono>

#pragma comment(lib, "shell32.lib")

namespace toollaunch {

    // Global instance
    std::unique_ptr<ToolLauncher> g_toolLauncher = nullptr;

    ToolLauncher::ToolLauncher()
        : m_chromePath("")
        , m_projectRoot(".")
    {
    }

    ToolLauncher::~ToolLauncher() {
        shutdown();
    }

    void ToolLauncher::initialize() {
        ocean::info("[ToolLauncher] Initializing tool launcher system");

        // Check for environment variable override first
        char envBrowser[MAX_PATH];
        if (GetEnvironmentVariableA("ARCTIC_BROWSER_PATH", envBrowser, MAX_PATH) > 0) {
            if (GetFileAttributesA(envBrowser) != INVALID_FILE_ATTRIBUTES) {
                m_chromePath = envBrowser;
                ocean::info("[ToolLauncher] Using browser from ARCTIC_BROWSER_PATH: " + m_chromePath);
            } else {
                ocean::warning("[ToolLauncher] ARCTIC_BROWSER_PATH set but file not found: " + std::string(envBrowser));
                detectBrowserPath();
            }
        } else {
            detectBrowserPath();
        }

        // Set project root (assume we're in build-*/bin/Debug or similar)
        char currentDir[MAX_PATH];
        GetCurrentDirectoryA(MAX_PATH, currentDir);
        m_projectRoot = currentDir;

        // Navigate up to project root (from build-x86/bin/Debug -> ../../..)
        size_t pos = m_projectRoot.find("\\build-");
        if (pos != std::string::npos) {
            m_projectRoot = m_projectRoot.substr(0, pos);
        }

        ocean::info("[ToolLauncher] Project root: " + m_projectRoot);

        // Load default tool registry
        loadToolRegistry("");
    }

    void ToolLauncher::loadToolRegistry(const std::string& registryPath) {
        // For now, use hardcoded tool definitions
        // Later this can be loaded from XML or JSON config

        m_tools.clear();

        // Arctic Studio Prime - Scene Editor
        {
            ToolDefinition tool;
            tool.id = "arctic-studio-prime";
            tool.displayName = "Scene Editor";
            tool.path = m_projectRoot + "\\apps\\tools\\arctic-studio-prime";
            tool.url = "http://localhost:3001";
            tool.port = 3001;
            tool.startCommand = "npm start";
            tool.icon = "📐";
            tool.launchInBrowser = true;
