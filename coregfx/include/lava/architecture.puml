@startuml Lava Architecture - Component Diagram

!define VULKAN_COLOR #FF6B6B
!define LAVA_CORE_COLOR #4ECDC4
!define LAVA_UTIL_COLOR #95E1D3
!define CLIENT_COLOR #FFE66D

title Lava - Reusable Vulkan Toolkit\nComponent Architecture

' External Dependencies
package "Vulkan SDK" <<External>> VULKAN_COLOR {
    [VkInstance]
    [VkDevice]
    [VkBuffer]
    [VkImage]
    [VkPipeline]
    [VkCommandBuffer]
}

package "GLM" <<External>> {
    [Math Types]
}

' Lava Components
package "lava" {

    ' Core Initialization
    package "lava/core" LAVA_CORE_COLOR {
        [DeviceBuilder] as DeviceBuilder
        [SwapchainBuilder] as SwapchainBuilder
        [CommandPoolManager] as CommandPoolManager
    }

    ' Resource Management
    package "lava/resources" LAVA_UTIL_COLOR {
        [Buffer] as LavaBuffer
        [Image] as LavaImage
        [MemoryAllocator] as MemoryAllocator
    }

    ' Command Helpers
    package "lava/commands" LAVA_UTIL_COLOR {
        [ImmediateCommandBuffer] as ImmediateCmd
        [CommandHelpers] as CmdHelpers
    }

    ' Synchronization
    package "lava/sync" LAVA_UTIL_COLOR {
        [Fence] as LavaFence
        [Semaphore] as LavaSemaphore
        [FrameSync] as FrameSync
    }

    ' Pipeline Utilities
    package "lava/pipeline" LAVA_UTIL_COLOR {
        [ShaderModule] as ShaderModule
        [GraphicsPipelineBuilder] as PipelineBuilder
        [DescriptorSetBuilder] as DescriptorBuilder
    }

    ' Debug and Validation
    package "lava/debug" LAVA_UTIL_COLOR {
        [ValidationLayers] as ValidationLayers
        [DebugMarkers] as DebugMarkers
        [StateDumper] as StateDumper
    }

    ' Extensions and Features
    package "lava/extensions" LAVA_UTIL_COLOR {
        [ExtensionManager] as ExtensionManager
        [FeatureDetector] as FeatureDetector
    }

    ' Memory Management
    package "lava/memory" LAVA_UTIL_COLOR {
        [StagingBuffer] as StagingBuffer
        [MemoryTracker] as MemoryTracker
    }
}

' Client Applications
package "Arctic Game Client Projects" CLIENT_COLOR {
    [coregfx] as CoreGFX
    [elyrion.coregfx.renderer] as Elyrion
    [data-driven-renderer] as DataDriven
    [cryo-studio-server] as CryoStudio
}

' === Core Dependencies ===
DeviceBuilder --> [VkDevice] : creates
DeviceBuilder --> ExtensionManager : uses
DeviceBuilder --> FeatureDetector : uses
DeviceBuilder --> ValidationLayers : optional

SwapchainBuilder --> [VkDevice] : requires
SwapchainBuilder ..> [VkImage] : creates chain

CommandPoolManager --> [VkDevice] : requires
CommandPoolManager --> [VkCommandBuffer] : allocates

' === Resource Management Dependencies ===
LavaBuffer --> [VkDevice] : requires
LavaBuffer --> [VkBuffer] : wraps (RAII)
LavaBuffer --> MemoryAllocator : uses

LavaImage --> [VkDevice] : requires
LavaImage --> [VkImage] : wraps (RAII)
LavaImage --> MemoryAllocator : uses
LavaImage --> CmdHelpers : uses (transitions)

MemoryAllocator --> [VkDevice] : requires
MemoryAllocator --> MemoryTracker : optional

' === Command Buffer Dependencies ===
ImmediateCmd --> CommandPoolManager : uses
ImmediateCmd --> [VkCommandBuffer] : executes
ImmediateCmd --> LavaFence : uses (sync)

CmdHelpers --> [VkCommandBuffer] : operates on
CmdHelpers --> [VkBuffer] : copies
CmdHelpers --> [VkImage] : blits/transitions

' === Synchronization Dependencies ===
LavaFence --> [VkDevice] : requires
LavaFence ..> VkFence : wraps (RAII)

LavaSemaphore --> [VkDevice] : requires
LavaSemaphore ..> VkSemaphore : wraps (RAII)

FrameSync --> LavaFence : manages
FrameSync --> LavaSemaphore : manages
FrameSync --> [VkDevice] : requires

' === Pipeline Dependencies ===
ShaderModule --> [VkDevice] : requires
ShaderModule ..> VkShaderModule : wraps (RAII)

PipelineBuilder --> ShaderModule : uses
PipelineBuilder --> [VkPipeline] : builds
PipelineBuilder --> [VkDevice] : requires

DescriptorBuilder --> [VkDevice] : requires
DescriptorBuilder ..> VkDescriptorSetLayout : builds
DescriptorBuilder ..> VkDescriptorSet : allocates

' === Debug Dependencies ===
ValidationLayers --> [VkInstance] : requires
ValidationLayers ..> VkDebugUtilsMessengerEXT : creates

DebugMarkers --> [VkDevice] : requires
DebugMarkers --> [VkCommandBuffer] : annotates
DebugMarkers --> [Math Types] : uses (colors)

StateDumper --> [VkDevice] : queries
StateDumper --> [VkPipeline] : inspects
StateDumper ..> VkPhysicalDevice : queries info

' === Extension/Feature Dependencies ===
ExtensionManager --> [VkInstance] : queries
ExtensionManager ..> VkPhysicalDevice : checks support

FeatureDetector ..> VkPhysicalDevice : queries
FeatureDetector ..> VkPhysicalDeviceFeatures : returns

' === Memory Management Dependencies ===
StagingBuffer --> LavaBuffer : extends
StagingBuffer --> CmdHelpers : uses (copy)
StagingBuffer --> ImmediateCmd : uses (upload)

MemoryTracker ..> VkDeviceMemory : tracks

' === Client Application Dependencies ===
CoreGFX --> LavaBuffer : uses
CoreGFX --> LavaImage : uses
CoreGFX --> DeviceBuilder : uses
CoreGFX --> PipelineBuilder : uses

Elyrion --> DeviceBuilder : uses
Elyrion --> LavaBuffer : uses
Elyrion --> FrameSync : uses
Elyrion --> ShaderModule : uses

DataDriven --> PipelineBuilder : uses
DataDriven --> DescriptorBuilder : uses
DataDriven --> LavaBuffer : uses
DataDriven --> FrameSync : uses

CryoStudio --> DeviceBuilder : uses
CryoStudio --> StagingBuffer : uses
CryoStudio --> StateDumper : uses

' === Inter-Lava Component Relations ===
note right of lava
  All Lava components are:
  - **Zero-cost abstractions** (RAII)
  - **Composable** (no forced dependencies)
  - **Interoperable** (exposes Vulkan handles)
  - **Optional** (can mix with raw Vulkan)
end note

note bottom of DeviceBuilder
  **Builder Pattern**
  Simplifies complex initialization
  with fluent interface
end note

note bottom of LavaBuffer
  **RAII Wrapper**
  Automatic cleanup on destruction
  Prevents resource leaks
end note

note bottom of FrameSync
  **High-Level Helper**
  Manages per-frame synchronization
  primitives (fences + semaphores)
end note

@enduml