# Game Server Example: Spawning with Overrides
# Shows how to customize instances without changing templates

frame_number: 0
timestamp_ms: 0
type: FULL

# ============================================================================
# Minimal Spawns (No Overrides) - Use Template Defaults
# ============================================================================
groups {
  group_id: "minimal_spawns"
  purpose: "template_instance_spawn"
  priority: NORMAL

  # Basic NPC - Uses all template defaults
  data {
    [type.googleapis.com/cryo.templates.SpawnTemplateInstance] {
      instance_id: "npc_001"
      template_id: "npc_merchant"
      transform {
        position { x: 10.0 y: 0.0 z: 5.0 }
        rotation { x: 0.0 y: 0.707 z: 0.0 w: 0.707 }
      }
      # No overrides = 112 bytes only!
    }
  }

  # Basic door - Uses all template defaults
  data {
    [type.googleapis.com/cryo.templates.SpawnTemplateInstance] {
      instance_id: "door_001"
      template_id: "door_standard"
      transform {
        position { x: 5.0 y: 0.0 z: 0.0 }
        rotation { x: 0.0 y: 0.0 z: 0.0 w: 1.0 }
        scale { x: 1.0 y: 2.0 z: 0.1 }
      }
      # No overrides = 112 bytes only!
    }
  }
}

# ============================================================================
# Spawns with Property Overrides
# ============================================================================
groups {
  group_id: "overridden_spawns"
  purpose: "template_instance_spawn"
  priority: NORMAL

  # Locked door (property override)
  data {
    [type.googleapis.com/cryo.templates.SpawnTemplateInstance] {
      instance_id: "door_locked_001"
      template_id: "door_standard"
      transform { position { x: 15.0 y: 0.0 z: 0.0 } }

      # Override: Lock the door
      initial_properties {
        key: "is_locked"
        value: "true"
      }

      # Override: Requires iron key
      initial_properties {
        key: "required_key"
        value: "iron_key"
      }

      # Size: ~144 bytes (32 bytes extra for 2 overrides)
    }
  }

  # Rare treasure chest (loot override)
  data {
    [type.googleapis.com/cryo.templates.SpawnTemplateInstance] {
      instance_id: "chest_rare_001"
      template_id: "treasure_chest"
      transform { position { x: 20.0 y: 0.0 z: 8.0 } }

      # Override: Better loot table
      initial_properties {
        key: "loot_table"
        value: "treasure_rare"
      }

      # Size: ~128 bytes (16 bytes extra for 1 override)
    }
  }

  # Grumpy merchant (no wave greeting)
  data {
    [type.googleapis.com/cryo.templates.SpawnTemplateInstance] {
      instance_id: "npc_grumpy_001"
      template_id: "npc_merchant"
      transform { position { x: 25.0 y: 0.0 z: 10.0 } }

      # Override: Custom greeting
      initial_properties {
        key: "greeting_text"
        value: "What do you want?"
      }

      # Disable wave trigger
      trigger_overrides {
        trigger_id: "trigger_npc_wave"
        enabled: false
      }

      # Size: ~144 bytes (32 bytes extra)
    }
  }
}

# ============================================================================
# Complex Overrides (Linked Entities)
# ============================================================================
groups {
  group_id: "linked_spawns"
  purpose: "template_instance_spawn"
  priority: NORMAL

  # Pressure plate
  data {
    [type.googleapis.com/cryo.templates.SpawnTemplateInstance] {
      instance_id: "plate_001"
      template_id: "pressure_plate"
      transform { position { x: 8.0 y: 0.0 z: 2.0 } }

      # Link to locked door
      initial_properties {
        key: "linked_entity"
        value: "door_locked_001"
      }

      # Size: ~128 bytes (16 bytes extra)
    }
  }

  # Lever switch
  data {
    [type.googleapis.com/cryo.templates.SpawnTemplateInstance] {
      instance_id: "lever_001"
      template_id: "lever_switch"
      transform { position { x: 12.0 y: 0.5 z: 4.0 } }

      # Link to multiple entities
      initial_properties {
        key: "linked_entities"
        value: "door_001,door_locked_001,torch_001"
      }

      # Start in ON position
      initial_properties {
        key: "is_on"
        value: "true"
      }

      # Size: ~160 bytes (48 bytes extra for 2 overrides)
    }
  }
}

# ============================================================================
# Scaled Entities (Visual Variations)
# ============================================================================
groups {
  group_id: "scaled_spawns"
  purpose: "template_instance_spawn"
  priority: NORMAL

  # Small pressure plate
  data {
    [type.googleapis.com/cryo.templates.SpawnTemplateInstance] {
      instance_id: "plate_small_001"
      template_id: "pressure_plate"
      transform {
        position { x: 18.0 y: 0.0 z: 6.0 }
        scale { x: 0.5 y: 0.5 z: 0.5 }  # Half size = smaller trigger
      }
      # Size: 112 bytes (scale is part of transform, not override)
    }
  }

  # Large proximity sensor (10m radius)
  data {
    [type.googleapis.com/cryo.templates.SpawnTemplateInstance] {
      instance_id: "sensor_large_001"
      template_id: "proximity_sensor"
      transform {
        position { x: 30.0 y: 0.0 z: 15.0 }
        scale { x: 2.0 y: 2.0 z: 2.0 }  # Double size = 10m radius
      }
      # Size: 112 bytes
    }
  }

  # Giant treasure chest (boss loot)
  data {
    [type.googleapis.com/cryo.templates.SpawnTemplateInstance] {
      instance_id: "chest_boss_001"
      template_id: "treasure_chest"
      transform {
        position { x: 50.0 y: 0.0 z: 25.0 }
        scale { x: 2.0 y: 2.0 z: 2.0 }  # Visually impressive
      }

      # Boss loot table
      initial_properties {
        key: "loot_table"
        value: "boss_legendary"
      }

      # Size: ~128 bytes (16 bytes extra)
    }
  }
}

# ============================================================================
# Quest-Specific Overrides
# ============================================================================
groups {
  group_id: "quest_spawns"
  purpose: "template_instance_spawn"
  priority: NORMAL

  # Quest giver NPC
  data {
    [type.googleapis.com/cryo.templates.SpawnTemplateInstance] {
      instance_id: "npc_quest_giver_001"
      template_id: "npc_merchant"
      transform { position { x: 5.0 y: 0.0 z: 2.0 } }

      # Quest marker
      initial_properties {
        key: "has_quest"
        value: "true"
      }
      initial_properties {
        key: "quest_id"
        value: "main_quest_chapter_1"
      }
      initial_properties {
        key: "quest_marker_color"
        value: "255,255,0"  # Yellow exclamation mark
      }

      # Size: ~176 bytes (64 bytes extra for 3 overrides)
    }
  }

  # Quest chest (specific item)
  data {
    [type.googleapis.com/cryo.templates.SpawnTemplateInstance] {
      instance_id: "chest_quest_001"
      template_id: "treasure_chest"
      transform { position { x: 40.0 y: 0.0 z: 20.0 } }

      # Quest-specific
      initial_properties {
        key: "loot_table"
        value: "quest_ancient_artifact"
      }
      initial_properties {
        key: "is_quest_chest"
        value: "true"
      }
      initial_properties {
        key: "quest_id"
        value: "ancient_ruins_quest"
      }

      # Size: ~176 bytes (64 bytes extra for 3 overrides)
    }
  }
}

# ============================================================================
# Atmospheric/Decorative Variations
# ============================================================================
groups {
  group_id: "atmospheric_spawns"
  purpose: "template_instance_spawn"
  priority: NORMAL

  # Dim torch (dying light)
  data {
    [type.googleapis.com/cryo.templates.SpawnTemplateInstance] {
      instance_id: "torch_dim_001"
      template_id: "torch_light"
      transform { position { x: 3.0 y: 1.5 z: 1.0 } }

      initial_properties {
        key: "light_intensity"
        value: "0.5"  # 50% brightness
      }

      # Size: ~128 bytes (16 bytes extra)
    }
  }

  # Bright torch (main light)
  data {
    [type.googleapis.com/cryo.templates.SpawnTemplateInstance] {
      instance_id: "torch_bright_001"
      template_id: "torch_light"
      transform { position { x: 10.0 y: 1.5 z: 5.0 } }

      initial_properties {
        key: "light_intensity"
        value: "2.0"  # 200% brightness
      }
      initial_properties {
        key: "light_color"
        value: "255,200,100"  # Warmer color
      }

      # Size: ~144 bytes (32 bytes extra for 2 overrides)
    }
  }

  # Blue magical torch
  data {
    [type.googleapis.com/cryo.templates.SpawnTemplateInstance] {
      instance_id: "torch_magic_001"
      template_id: "torch_light"
      transform { position { x: 15.0 y: 1.5 z: 8.0 } }

      initial_properties {
        key: "light_color"
        value: "100,150,255"  # Blue
      }
      initial_properties {
        key: "is_magical"
        value: "true"
      }

      # Size: ~144 bytes (32 bytes extra)
    }
  }
}

# ============================================================================
# Already-Opened/Used States
# ============================================================================
groups {
  group_id: "used_state_spawns"
  purpose: "template_instance_spawn"
  priority: NORMAL

  # Already opened chest (respawn scenario)
  data {
    [type.googleapis.com/cryo.templates.SpawnTemplateInstance] {
      instance_id: "chest_opened_001"
      template_id: "treasure_chest"
      transform { position { x: 22.0 y: 0.0 z: 12.0 } }

      # Already opened
      initial_properties {
        key: "is_open"
        value: "true"
      }
      initial_properties {
        key: "has_been_opened"
        value: "true"
      }

      # Disable all triggers
      trigger_overrides {
        trigger_id: "trigger_chest_hover"
        enabled: false
      }
      trigger_overrides {
        trigger_id: "trigger_chest_open"
        enabled: false
      }

      # Size: ~160 bytes (48 bytes extra)
    }
  }

  # Already open door (stays open)
  data {
    [type.googleapis.com/cryo.templates.SpawnTemplateInstance] {
      instance_id: "door_open_001"
      template_id: "door_standard"
      transform { position { x: 28.0 y: 0.0 z: 14.0 } }

      # Start open
      initial_properties {
        key: "is_open"
        value: "true"
      }

      # Disable auto-close
      trigger_overrides {
        trigger_id: "trigger_door_autoclose"
        enabled: false
      }

      # Size: ~144 bytes (32 bytes extra)
    }
  }
}

metadata {
  frame_size_bytes: 3072  # ~3 KB for 20+ entities with overrides
  uncompressed_size_bytes: 4096
  message_count: 20
  group_count: 7
  quality_factor: 1.0
  is_keyframe: true
}

# ============================================================================
# COMPARISON:
#
# Traditional approach (20 entities):
#   20 × 5.2 KB = 104 KB (full definitions)
#
# With templates (20 entities, mixed overrides):
#   - 10 minimal (112 bytes each) = 1.1 KB
#   - 10 with overrides (128-176 bytes each) = 1.5 KB
#   Total: ~2.6 KB
#
# Savings: 101.4 KB = 97.5% reduction!
#
# Templates (all 10 types, loaded from CDN once):
#   ~20 KB total, cached forever
# ============================================================================