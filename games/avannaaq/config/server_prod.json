{
  "server": {
    "name": "Avannaaq Production Server",
    "port": 8080,
    "max_connections": 100,
    "log_level": "info"
  },
  "network": {
    "timeout_ms": 10000,
    "heartbeat_interval_ms": 2000,
    "max_packet_size": 65536
  },
  "paths": {
    "content": "/opt/avannaaq/content",
    "data": "/opt/avannaaq/data",
    "logs": "/var/log/avannaaq",
    "database": "/opt/avannaaq/data/game.db"
  },
  "features": {
    "hot_reload": false,
    "debug_rendering": false,
    "console_enabled": false
  },
  "security": {
    "enable_rate_limiting": true,
    "max_requests_per_minute": 100,
    "enable_ddos_protection": true
  }
}
